# SEC EDGAR listener configurations

# SEC Fair Access compliance: User-Agent MUST include your app name and contact email.
# Example: PEADEngine/1.0.0 (contact@domain.com)
SEC_USER_AGENT=PEADEngine/1.0.0 (contact@example.com)

# SEC EDGAR URL feed for current filings in Atom format
SEC_FEED_URL=https://www.sec.gov/cgi-bin/browse-edgar?action=getcurrent&owner=include&count=100&output=atom

# Polling interval in milliseconds (default: 30000 ms = 30 seconds)
# Do not set this lower than 10000 ms to avoid getting rate-limited by the SEC.
POLL_INTERVAL_MS=30000

# Comma-separated list of filing form types to capture
# Note: This will matches prefixes as well (e.g., 10-K will match 10-K and 10-K/A)
FORM_TYPES=10-K,10-Q

# Storage configuration
CSV_PATH=data/filings.csv
SEEN_CACHE_PATH=data/seen_filings.json

# API Keys
FMP_API_KEY=your_fmp_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Database Configuration
DATABASE_URL=postgresql://pead_admin:pead_secure_password@localhost:5432/pead_engine
